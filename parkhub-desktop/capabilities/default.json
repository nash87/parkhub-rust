{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for ParkHub Desktop — minimum surface the web UI needs to reach the backend and persist first-run state.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "opener:default",
    "shell:allow-open",
    "http:default",
    "http:allow-fetch",
    "fs:default",
    "dialog:default",
    "store:default",
    "notification:default",
    "os:default",
    "process:default",
    "deep-link:default"
  ]
}
