{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "coverage",
    "**/*.stories.tsx",
    "**/*.stories.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node", "vitest/globals"],
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true
  }
}
