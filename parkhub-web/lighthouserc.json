{
  "ci": {
    "collect": {
      "startServerCommand": "npx astro preview --port 4321",
      "startServerReadyPattern": "localhost:4321",
      "url": ["http://localhost:4321/"],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", {"minScore": 0.8}],
        "categories:best-practices": ["warn", {"minScore": 0.8}]
      }
    }
  }
}
