{
  "name": "parkhub-web",
  "type": "module",
  "version": "5.0.8",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:php": "VITE_API_URL= astro build && cp -r dist/* ../public/",
    "build:rust": "VITE_API_URL= astro build && rm -rf ../parkhub-rust/parkhub-web/dist && cp -r dist ../parkhub-rust/parkhub-web/dist",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:coverage": "tsx scripts/locale-coverage.mjs",
    "test:e2e:local": "bash ../scripts/e2e-local.sh",
    "test:e2e:ui": "bash ../scripts/e2e-local.sh --ui",
    "test:e2e:design": "bash ../scripts/e2e-local.sh e2e/design-*.spec.ts",
    "test:a11y": "bash ../scripts/e2e-local.sh e2e/design-accessibility.spec.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/atkinson-hyperlegible": "^5.2.7",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@number-flow/react": "^0.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "4.2.3",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.8",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "4.2.3",
    "uplot": "1.6.32",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": "^7.3.2"
  }
}
