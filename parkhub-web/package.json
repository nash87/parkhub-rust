{
  "name": "parkhub-web",
  "type": "module",
  "version": "4.14.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:php": "VITE_API_URL= astro build && cp -r dist/* ../parkhub-php/public/",
    "build:rust": "VITE_API_URL= astro build && rm -rf ../parkhub-rust/parkhub-web/dist && cp -r dist ../parkhub-rust/parkhub-web/dist",
    "preview": "astro preview",
    "preview:spa": "node scripts/spa-preview.mjs",
    "astro": "astro",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "bash ../scripts/e2e-local.sh --headed",
    "test:watch": "vitest",
    "i18n:coverage": "tsx scripts/locale-coverage.mjs",
    "test:e2e:local": "bash ../scripts/e2e-local.sh",
    "test:e2e:ui": "bash ../scripts/e2e-local.sh --ui",
    "test:e2e:design": "bash ../scripts/e2e-local.sh e2e/design-*.spec.ts",
    "test:a11y": "bash ../scripts/e2e-local.sh e2e/design-accessibility.spec.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@number-flow/react": "^0.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.7",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.2",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.1",
    "uplot": "1.6.32",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.1",
    "msw": "^2.13.4",
    "vitest": "^4.1.0"
  }
}
