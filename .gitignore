# Rust build artifacts
/target/
# Cargo.lock is intentionally committed (binary crate — reproducible Docker builds)

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Slint generated
*.slint.rs

# Local config
.env
.env.*
!.env.example
!docker-compose.override.yml.example
*.local.toml
config.toml.local

# Logs
*.log
logs/

# User data
data/
layouts/

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# Debug files
*.pdb

# Certificate and key files — never commit private keys
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Database files
*.db
*.sqlite
*.redb

# Node/frontend artifacts
node_modules/
dist/
parkhub-web/dist/

# Package files
*.zip
*.tar.gz
parkhub-web-old/
.gstack/

# Playwright
playwright-report/
test-results/
blob-report/

# Lighthouse CI local output (JSON + HTML reports)
.lighthouseci/

# Coverage
coverage/
*.lcov

# Local dev tooling (not for public repo)
.aoe/
.claude/
.forge-operator/
.fop/

# insta snapshot scratch files — accepted *.snap files ARE committed;
# only .snap.new (pending review) is ignored. See src/api/snapshots.rs.
*.snap.new
*.pending-snap

# ts-rs default output: the `gen-types` feature writes additional copies of
# external-crate bindings (e.g. serde_json::Value) to each crate's
# `bindings/` directory regardless of the path passed to `export_all_to`.
# Our authoritative output lives in parkhub-web/src/generated/types/ (which
# the CI drift-gate watches); these stray copies are build byproducts.
parkhub-server/bindings/
parkhub-common/bindings/
