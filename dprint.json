{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 100,
  "indentWidth": 2,
  "useTabs": false,
  "newLineKind": "lf",
  "json": {
    "trailingCommas": "never"
  },
  "markdown": {
    "lineWidth": 100,
    "textWrap": "maintain",
    "emphasisKind": "underscores",
    "strongKind": "asterisks"
  },
  "toml": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "yaml": {
    "lineWidth": 100
  },
  "excludes": [
    "**/node_modules",
    "**/target",
    "**/dist",
    "**/.svelte-kit",
    "Cargo.lock",
    "package-lock.json",
    "**/*.min.js",
    "**/*.min.css",
    ".claude/worktrees/**",
    "parkhub-web/dist/**",
    "parkhub-web/.astro/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.20.0.wasm",
    "https://plugins.dprint.dev/markdown-0.18.0.wasm",
    "https://plugins.dprint.dev/toml-0.7.1.wasm",
    "https://plugins.dprint.dev/g-plane/yaml-0.7.0.wasm"
  ]
}
