# direnv config (MIT, direnv/direnv) — auto-activates this repo's mise
# toolchain when you cd into the directory.
#
# First-time setup:
#
#     direnv allow .
#
# After that, the tools listed in .mise.toml are on PATH whenever your
# shell's CWD is anywhere inside this repo.

use mise

# Repo-local overrides — tweak per-developer without touching .mise.toml.
# Uncomment as needed:
# export RUST_LOG=parkhub_server=debug,tower_http=info
# export DATABASE_URL=postgres://parkhub:parkhub@localhost:5433/parkhub_dev
# export VITE_API_URL=http://127.0.0.1:8080
